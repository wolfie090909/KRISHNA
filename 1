<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Krishna Mobiles: Premium refurbished Apple and Samsung phones from Dubai. Worldwide shipping, certified quality, sustainable tech at unbeatable prices. Established 2021 in DAFZA.">
    <meta name="keywords" content="refurbished mobiles Dubai, used Apple phones wholesale, certified pre-owned smartphones UAE, sustainable electronics worldwide, Krishna Mobiles DAFZA">
    <title>Krishna Mobiles - Premium Refurbished Mobiles Worldwide</title>
    <!-- SEO Schema Markup for Organization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Krishna Mobiles FZCO",
      "url": "https://krishnamobiles.co",
      "logo": "https://krishnamobiles.co/logo.png",
      "foundingDate": "2021",
      "founders": [{"@type": "Person", "name": "Kundan Yadav"}],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "7 WA-3002, Dubai Airport Freezone",
        "addressLocality": "Dubai",
        "addressRegion": "Dubai",
        "postalCode": "",
        "addressCountry": "AE"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+971-XXXX-XXXX",
        "contactType": "Customer Service"
      }
    }
    </script>
    <style>
        /* Global Styles - Modern, Clean, Trustworthy Palette: Blues for Reliability, Gold Accents for Premium */
        body { font-family: 'Montserrat', sans-serif; margin: 0; padding: 0; color: #333; background: #f9f9f9; }
        header { background: linear-gradient(135deg, #0056a0, #003366); color: white; padding: 20px; text-align: center; }
        nav { background: #003366; padding: 10px; }
        nav ul { list-style: none; margin: 0; padding: 0; display: flex; justify-content: center; }
        nav li { margin: 0 15px; }
        nav a { color: white; text-decoration: none; font-weight: bold; }
        .hero { background: url('https://via.placeholder.com/1920x600?text=Hero+Image+-+Dubai+Skyline+with+Mobiles') no-repeat center/cover; height: 600px; display: flex; align-items: center; justify-content: center; color: white; text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }
        .hero h1 { font-size: 3em; }
        section { padding: 50px 20px; max-width: 1200px; margin: auto; }
        .products { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .product-card { background: white; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); padding: 20px; text-align: center; }
        .product-card img { max-width: 100%; border-radius: 10px; }
        form { display: grid; gap: 10px; max-width: 600px; margin: auto; }
        button { background: #ffd700; color: #003366; border: none; padding: 10px; font-weight: bold; cursor: pointer; }
        footer { background: #003366; color: white; text-align: center; padding: 20px; }
        /* Responsiveness */
        @media (max-width: 768px) { .hero h1 { font-size: 2em; } nav ul { flex-direction: column; } }
        /* JS-Enabled Interactivity */
        .testimonial { opacity: 0; transition: opacity 1s; }
        .show { opacity: 1; }
    </style>
</head>
<body>
    <header>
        <h2>Krishna Mobiles FZCO</h2>
        <p>Established 2021 by Kundan Yadav | 7 WA-3002, Dubai Airport Freezone</p>
    </header>
    <nav>
        <ul>
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About Us</a></li>
            <li><a href="#products">Products</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>
    <section id="home" class="hero">
        <h1>Unlock Premium Refurbished Mobiles Worldwide – Sustainable, Reliable, Affordable</h1>
    </section>
    <section id="about">
        <h2>About Krishna Mobiles</h2>
        <p>Founded in 2021 by visionary entrepreneur Kundan Yadav, Krishna Mobiles is Dubai's premier destination for certified refurbished and pre-owned smartphones. From our strategic base in Dubai Airport Freezone (DAFZA), we export to over 50 countries, offering Apple, Samsung, and more with full warranties, eco-friendly practices, and unbeatable prices. We're not just sellers—we're your global partner in sustainable tech, reducing e-waste while delivering like-new quality.</p>
        <ul>
            <li>Global Shipping: Fast, secure delivery worldwide.</li>
            <li>Certified Quality: Every device rigorously tested and graded.</li>
            <li>Trustworthy: 100% Guarantee, Huge Savings, Expert Support.</li>
        </ul>
    </section>
    <section id="products">
        <h2>Our Premium Products</h2>
        <div class="products">
            <div class="product-card">
                <img src="https://via.placeholder.com/250?text=Apple+iPhone+15+Pro+Max" alt="Refurbished Apple iPhone 15 Pro Max - Krishna Mobiles Dubai">
                <h3>Apple iPhone 15 Pro Max</h3>
                <p>Certified pre-owned, 1-year warranty, worldwide specs. Starting at $799.</p>
            </div>
            <div class="product-card">
                <img src="https://via.placeholder.com/250?text=Samsung+Galaxy+S24" alt="Refurbished Samsung Galaxy S24 - Krishna Mobiles UAE">
                <h3>Samsung Galaxy S24</h3>
                <p>Graded A+, eco-friendly refurb, bulk wholesale available.</p>
            </div>
            <!-- Add more cards as needed -->
        </div>
    </section>
    <section id="testimonials">
        <h2>What Our Customers Say</h2>
        <div class="testimonial"> "Krishna Mobiles transformed our inventory—fast shipping to India, top quality!" – Raj, Wholesaler </div>
        <div class="testimonial"> "Reliable partner for Africa markets. Sustainable and affordable." – Aisha, Retailer </div>
    </section>
    <section id="contact">
        <h2>Contact Us</h2>
        <form id="contactForm">
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea placeholder="Your Message" required></textarea>
            <button type="submit">Send Message</button>
        </form>
        <p>Or chat via WhatsApp: <a href="https://wa.me/+971XXXXXXXX">+971-XXXX-XXXX</a></p>
    </section>
    <footer>
        <p>&copy; 2025 Krishna Mobiles FZCO. All rights reserved. | SEO-Optimized for Global Reach</p>
    </footer>
    <script>
        // Simple JS for Interactivity & Traffic Strategy (e.g., Form Submit Alert, Fade-In Testimonials)
        document.addEventListener('DOMContentLoaded', () => {
            const testimonials = document.querySelectorAll('.testimonial');
            testimonials.forEach((el, i) => setTimeout(() => el.classList.add('show'), i * 500));
            
            document.getElementById('contactForm').addEventListener('submit', (e) => {
                e.preventDefault();
                alert('Message Sent! Our team will respond within 24 hours.');
                // In production, integrate with EmailJS or backend for real submissions
            });
        });
    </script>
</body>
</html>

<script>
  // Lightweight, no-tracking interactivity. No external requests.
  (function () {
    'use strict';

    var FX_RATE = 0.9210; // demo: 1 USD = 0.9210 EUR
    var FEE = 1.99;

    var amt = document.getElementById('send-amt');
    var recv = document.getElementById('recv-amt');
    var total = document.getElementById('total-out');
    var fx = document.getElementById('fx-rate');
    var sendBtn = document.getElementById('send-btn');

    function fmt(n, digits) {
      digits = (digits == null) ? 2 : digits;
      return n.toLocaleString(undefined, { minimumFractionDigits: digits, maximumFractionDigits: digits });
    }

    function render(send) {
      amt.textContent = fmt(send);
      recv.textContent = fmt(send * FX_RATE);
      total.textContent = '$' + fmt(send + FEE);
      fx.textContent = '1 USD = ' + fmt(FX_RATE, 4) + ' EUR';
    }

    // Cycle the demo amount gently so the card feels alive without being noisy.
    var demoValues = [500, 1200, 75, 250];
    var i = 0;
    render(demoValues[0]);
    var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      setInterval(function () {
        i = (i + 1) % demoValues.length;
        render(demoValues[i]);
      }, 4500);
    }

    // Confirm-before-act: critical-action principle, even on a demo button.
    sendBtn.addEventListener('click', function () {
      var current = demoValues[i];
      var ok = window.confirm(
        'Confirm payment\n\n' +
        'Sending: $' + fmt(current) + ' USD\n' +
        'Recipient gets: €' + fmt(current * FX_RATE) + ' EUR\n' +
        'Fee: $' + fmt(FEE) + '\n' +
        'Total charged: $' + fmt(current + FEE) + '\n\n' +
        'This is a demo — no real money will move.'
      );
      if (ok) {
        sendBtn.textContent = 'Sent · receipt on its way';
        sendBtn.disabled = true;
        sendBtn.style.background = 'var(--accent)';
        setTimeout(function () {
          sendBtn.textContent = 'Send now';
          sendBtn.disabled = false;
          sendBtn.style.background = '';
        }, 2400);
      }
    });

    // Keep footer year fresh without server-side templating.
    document.getElementById('yr').textContent = String(new Date().getFullYear());
  })();
</script>

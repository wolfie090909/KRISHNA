    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const calculator = document.getElementById('feeCalculator');
            const amountInput = document.getElementById('amount');
            const destinationInput = document.getElementById('destination');
            const feeOutput = document.getElementById('fee');
            const recipientOutput = document.getElementById('recipient');
            const etaOutput = document.getElementById('eta');

            const currency = new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD'
            });

            const options = {
                domestic: { rate: 0.0095, fixed: 0.25, eta: 'Today' },
                international: { rate: 0.018, fixed: 2.5, eta: '1-2 days' },
                instant: { rate: 0.022, fixed: 0.75, eta: 'Minutes' }
            };

            function updateEstimate() {
                const amount = Math.max(Number(amountInput.value) || 0, 0);
                const selected = options[destinationInput.value];
                const fee = Math.min(amount, amount * selected.rate + selected.fixed);
                const recipientAmount = Math.max(amount - fee, 0);

                feeOutput.textContent = currency.format(fee);
                recipientOutput.textContent = currency.format(recipientAmount);
                etaOutput.textContent = selected.eta;
            }

            amountInput.addEventListener('input', updateEstimate);
            destinationInput.addEventListener('change', updateEstimate);
            updateEstimate();

            calculator.addEventListener('submit', (event) => {
                event.preventDefault();
                alert('Demo payout confirmed. In production, this step would create an idempotent payment intent for review and ledger posting.');
            });
        });
    </script>
